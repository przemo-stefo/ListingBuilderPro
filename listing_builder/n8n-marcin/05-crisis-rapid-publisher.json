      },
      "id": "if-approved",
      "name": "Zatwierdzono?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [1360, 300]
    },
    {
      "parameters": {
        "jsCode": "// Router — publikuj na wybranych platformach\nconst data = $('Parsuj 3 Wersje').first().json;\nconst platformy = data.platformy || 'fb,ig,x';\n\nreturn [{\n  json: {\n    ...data,\n    pub_fb: platformy.includes('fb'),\n    pub_ig: platformy.includes('ig'),\n    pub_x: platformy.includes('x')\n  }\n}];"
      },
      "id": "code-router",
      "name": "Router Platform",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
